# Ambiente
ENVIRONMENT=development

# Banco de dados (Postgres)
DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/mlaudit

# Redis (cache + fila)
REDIS_URL=redis://localhost:6379/0

# Mercado Livre
ML_API_BASE=https://api.mercadolibre.com
ML_SITE_ID=MLB
ML_CACHE_TTL_SECONDS=1800

# IA (Anthropic) — deixe vazio para usar o fallback determinístico
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Benchmark
BENCHMARK_MAX_COMPETITORS=10
